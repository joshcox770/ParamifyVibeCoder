# Copy this to `.env` for local development (npm run dev does this automatically).
# In production, set these in the Coolify dashboard instead of committing them.

# Database connection (SQLite).
#   Local:      file:./dev.db          (a file in the project root)
#   Production: file:/data/app.db       (a file on the Coolify persistent volume)
DATABASE_URL="file:./dev.db"
